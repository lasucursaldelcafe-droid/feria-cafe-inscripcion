{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      ".git/**",
      ".github/**"
    ],
    "rewrites": [
      {
        "source": "/competencia",
        "destination": "/competencia.html"
      },
      {
        "source": "/reglas",
        "destination": "/reglas-switch-championship.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(html|js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=3600"
          }
        ]
      }
    ]
  }
}

{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      ".git/**",
      ".github/**",
      "tools/**"
    ],
    "rewrites": [
      {
        "source": "/festival",
        "destination": "/index.html"
      },
      {
        "source": "/festival.html",
        "destination": "/index.html"
      },
      {
        "source": "/el-evento",
        "destination": "/el-evento.html"
      },
      {
        "source": "/actividades",
        "destination": "/actividades.html"
      },
      {
        "source": "/patrocinadores",
        "destination": "/patrocinadores.html"
      },
      {
        "source": "/inscripcion",
        "destination": "/inscripcion.html"
      },
      {
        "source": "/competencia",
        "destination": "/competencia.html"
      },
      {
        "source": "/reglas",
        "destination": "/reglas-switch-championship.html"
      },
      {
        "source": "/como-funciona",
        "destination": "/como-funciona-evento.html"
      },
      {
        "source": "/privacidad",
        "destination": "/privacidad.html"
      },
      {
        "source": "/qr",
        "destination": "/qr-inscripcion.html"
      },
      {
        "source": "/admin",
        "destination": "/admin.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.css",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=300, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.@(html|js)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=3600"
          }
        ]
      },
      {
        "source": "/admin**",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "noindex, nofollow"
          },
          {
            "key": "Cache-Control",
            "value": "no-store"
          }
        ]
      }
    ]
  }
}

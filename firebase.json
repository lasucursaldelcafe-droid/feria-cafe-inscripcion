{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      ".git/**",
      ".github/**",
      "tools/**",
      "js/firebase-config.js"
    ],
    "rewrites": [
      {
        "source": "/festival",
        "destination": "/index.html"
      },
      {
        "source": "/festival.html",
        "destination": "/index.html"
      },
      {
        "source": "/el-evento",
        "destination": "/el-evento.html"
      },
      {
        "source": "/actividades",
        "destination": "/actividades.html"
      },
      {
        "source": "/patrocinadores",
        "destination": "/patrocinadores.html"
      },
      {
        "source": "/stands",
        "destination": "/stands.html"
      },
      {
        "source": "/inscripcion",
        "destination": "/inscripcion.html"
      },
      {
        "source": "/competencia",
        "destination": "/competencia.html"
      },
      {
        "source": "/reglas",
        "destination": "/reglas-switch-championship.html"
      },
      {
        "source": "/como-funciona",
        "destination": "/como-funciona-evento.html"
      },
      {
        "source": "/privacidad",
        "destination": "/privacidad.html"
      },
      {
        "source": "/qr",
        "destination": "/qr-inscripcion.html"
      },
      {
        "source": "/admin",
        "destination": "/admin.html"
      },
      {
        "source": "/mi-stand",
        "destination": "/expositor.html"
      },
      {
        "source": "/expositor",
        "destination": "/expositor.html"
      }
    ],
    "headers": [
      {
        "source": "/robots.txt",
        "headers": [
          {
            "key": "Content-Type",
            "value": "text/plain; charset=utf-8"
          }
        ]
      },
      {
        "source": "/sitemap.xml",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/xml; charset=utf-8"
          }
        ]
      },
      {
        "source": "**/*.css",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=300, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.@(html|js)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=300, must-revalidate"
          }
        ]
      },
      {
        "source": "/admin**",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "noindex, nofollow"
          },
          {
            "key": "Cache-Control",
            "value": "no-store, no-cache, must-revalidate, max-age=0"
          },
          {
            "key": "Pragma",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "/js/admin-dashboard.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-store, no-cache, must-revalidate, max-age=0"
          }
        ]
      },
      {
        "source": "/mi-stand**",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "noindex, nofollow"
          },
          {
            "key": "Cache-Control",
            "value": "no-store, no-cache, must-revalidate, max-age=0"
          }
        ]
      },
      {
        "source": "/expositor**",
        "headers": [
          {
            "key": "X-Robots-Tag",
            "value": "noindex, nofollow"
          },
          {
            "key": "Cache-Control",
            "value": "no-store, no-cache, must-revalidate, max-age=0"
          }
        ]
      }
    ]
  }
}

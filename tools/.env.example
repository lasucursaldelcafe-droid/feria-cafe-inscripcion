# Copia este archivo como tools/.env y completa los valores.
# NO subas tools/.env al repositorio.

# Google Sheets (cuenta de servicio)
GOOGLE_SERVICE_ACCOUNT_JSON=C:\ruta\a\service-account.json
GOOGLE_SHEET_ID=
SHARE_SHEET_WITH=tu-correo@gmail.com

# URL de Apps Script Web App (termina en /exec)
SHEETS_WEB_APP_URL=
APPS_SCRIPT_URL=
APPS_SCRIPT_ID=

# Panel admin — correo autorizado en Firebase Google Sign-In
ALLOWED_ADMIN_EMAIL=lasucursaldelcafe@gmail.com

# Google Wallet — Issuer ID (CI lo aplica en cada deploy a main)
GOOGLE_WALLET_ISSUER_ID=3388000000023162431
# La firma usa la misma SA que Firebase Hosting (firebase-hosting-sa.json / FIREBASE_SERVICE_ACCOUNT)
# GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL=firebase-adminsdk-xxx@la-sucursal-del-cafe.iam.gserviceaccount.com

# Firebase Hosting
FIREBASE_PROJECT=la-sucursal-del-cafe
FIREBASE_TOKEN=
FIREBASE_SERVICE_ACCOUNT_JSON=
